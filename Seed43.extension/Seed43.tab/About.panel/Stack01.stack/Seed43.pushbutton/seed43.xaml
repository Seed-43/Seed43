<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Seed43"
    Width="500"
    SizeToContent="Height"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    TextElement.FontFamily="Segoe UI"
    Background="#3B4553">
<Window.Resources>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"      Value="#2B3340"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="BorderBrush"     Value="#208A3C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin"          Value="0,0,0,12"/>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#208A3C"/>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="Foreground"   Value="#F4FAFF"/>
        <Setter Property="Opacity"      Value="0.9"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="DimLabel" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="Foreground"   Value="#A0AABB"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="SmallBtn" TargetType="Button">
        <Setter Property="Background"      Value="#208A3C"/>
        <Setter Property="Foreground"      Value="#F4FAFF"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="14,5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2B933F"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#1A6E2E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#555555"/>
                            <Setter Property="Foreground" Value="#888888"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerBtn" TargetType="Button">
        <Setter Property="Background"      Value="#C53030"/>
        <Setter Property="Foreground"      Value="#F4FAFF"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="14,5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#a82828"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#8a2020"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#555555"/>
                            <Setter Property="Foreground" Value="#888888"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryBtn" TargetType="Button">
        <Setter Property="Background"      Value="#404553"/>
        <Setter Property="Foreground"      Value="#F4FAFF"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Padding"         Value="16,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4E5566"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#333B48"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseBtn" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="#F4FAFF"/>
        <Setter Property="FontSize"        Value="14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF5555"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#CC4444"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</Window.Resources>
<StackPanel>

    <!-- Header -->
    <Border Background="#232933" Height="64">
        <DockPanel Margin="20,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Seed" FontSize="24" FontWeight="Bold" Foreground="#208A3C"/>
                <TextBlock Text="43"   FontSize="24" Foreground="#F4FAFF"/>
                <TextBlock Text="  |  Tools" FontSize="14" Foreground="#F4FAFF"
                           VerticalAlignment="Bottom" Margin="0,0,0,2" Opacity="0.85"/>
            </StackPanel>
            <Button x:Name="header_close" Content="&#x2716;"
                    Style="{StaticResource CloseBtn}"
                    HorizontalAlignment="Right" DockPanel.Dock="Right"/>
        </DockPanel>
    </Border>

    <!-- Body -->
    <StackPanel Margin="20,16,20,20">

        <!-- Seed43 version card -->
        <Border Style="{StaticResource CardStyle}" Padding="16">
            <StackPanel>
                <TextBlock Text="Seed43 Extension"
                           Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                <TextBlock x:Name="s43_version" Text="Checking..."
                           Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="s43_changelog" Text=""
                           Style="{StaticResource DimLabel}" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tools divider -->
        <TextBlock Text="TOOLS" FontSize="11" FontWeight="SemiBold"
                   Foreground="#A0AABB" Margin="0,0,0,8"/>

        <!-- PyTransmit card -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>

                <!-- Always-visible header row -->
                <Border x:Name="pt_header" Background="Transparent"
                        Padding="16,12" Cursor="Hand">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="pt_dot" Width="7" Height="7"
                                     Fill="#A0AABB" Margin="0,0,6,0"/>
                            <TextBlock Text="PyTransmit"
                                       Style="{StaticResource SectionLabel}" Margin="0"/>
                            <TextBlock x:Name="pt_chevron" Text="&#x25BC;"
                                       FontSize="9" Foreground="#A0AABB"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="pt_action_btn" Content="Install"
                                Style="{StaticResource SmallBtn}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Progress bar -->
                <Border x:Name="pt_progress_wrap" Visibility="Collapsed"
                        Background="#2B3340" Padding="16,0,16,10">
                    <StackPanel>
                        <Border Background="#232933" CornerRadius="4" Height="4">
                            <ProgressBar x:Name="pt_progress"
                                         IsIndeterminate="True"
                                         Foreground="#208A3C"
                                         Background="Transparent"
                                         BorderThickness="0" Height="4"/>
                        </Border>
                        <TextBlock x:Name="pt_progress_lbl" Text=""
                                   Style="{StaticResource DimLabel}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Expanded detail -->
                <Border x:Name="pt_body" Visibility="Collapsed"
                        BorderBrush="#3a4555" BorderThickness="0,1,0,0"
                        Padding="16,12,16,14">
                    <StackPanel>
                        <TextBlock Text="Transmit Revit files with automatic sheet and link management."
                                   Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="pt_status_lbl" Text="Not installed"
                                   Style="{StaticResource DimLabel}"/>
                        <Border BorderBrush="#3a4555" BorderThickness="0,1,0,0" Margin="0,10,0,10"/>
                        <TextBlock x:Name="pt_changelog" Text=""
                                   Style="{StaticResource DimLabel}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- Footer -->
        <DockPanel Margin="0,4,0,0">
            <Button x:Name="footer_close" Content="Close"
                    Style="{StaticResource SecondaryBtn}"
                    Width="100" HorizontalAlignment="Right"/>
        </DockPanel>

    </StackPanel>
</StackPanel>
</Window>
