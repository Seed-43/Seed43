<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Layer Manager"
    Width="500"
    SizeToContent="Height"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen"
    Background="#3B4553"
    TextElement.FontFamily="Segoe UI">

    <Window.Resources>

        <!-- ── Drop Shadow ─────────────────────────────────────── -->
        <DropShadowEffect x:Key="CardShadow"
                          Color="Black" Opacity="0.2"
                          ShadowDepth="2" BlurRadius="4"/>

        <DropShadowEffect x:Key="HeaderShadow"
                          Color="Black" Opacity="0.3"
                          ShadowDepth="2" BlurRadius="6"/>

        <DropShadowEffect x:Key="PopupShadow"
                          Color="Black" Opacity="0.2"
                          ShadowDepth="2" BlurRadius="6"/>

        <!-- ── CardStyle ──────────────────────────────────────── -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"     Value="#2B3340"/>
            <Setter Property="CornerRadius"   Value="8"/>
            <Setter Property="Padding"        Value="16"/>
            <Setter Property="Margin"         Value="0,0,0,12"/>
            <Setter Property="Effect"         Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- ── SectionLabelStyle ─────────────────────────────── -->
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#208A3C"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>

        <!-- ── FieldLabelStyle ───────────────────────────────── -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#F4FAFF"/>
            <Setter Property="FontWeight"  Value="Medium"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
            <Setter Property="Opacity"     Value="0.9"/>
        </Style>

        <!-- ── ModernTextBoxStyle ────────────────────────────── -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"                Value="#F4FAFF"/>
            <Setter Property="Foreground"                Value="#2B3340"/>
            <Setter Property="BorderBrush"               Value="#208A3C"/>
            <Setter Property="BorderThickness"           Value="1"/>
            <Setter Property="Padding"                   Value="8,4"/>
            <Setter Property="FontSize"                  Value="12"/>
            <Setter Property="Height"                    Value="28"/>
            <Setter Property="VerticalContentAlignment"  Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#2B933F"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush"     Value="#2B933F"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── SmallButtonStyle ──────────────────────────────── -->
        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Background"              Value="#208A3C"/>
            <Setter Property="Foreground"              Value="#F4FAFF"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Padding"                 Value="12,4"/>
            <Setter Property="FontSize"                Value="11"/>
            <Setter Property="FontWeight"              Value="SemiBold"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Height"                  Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2B933F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A6E2E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── SecondaryButtonStyle ──────────────────────────── -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background"              Value="#404553"/>
            <Setter Property="Foreground"              Value="#F4FAFF"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Padding"                 Value="16,8"/>
            <Setter Property="FontSize"                Value="12"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4E5566"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#333B48"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── CloseButtonStyle ──────────────────────────────── -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#F4FAFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF5555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CC4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Layer Row CheckBox ────────────────────────────── -->
        <Style x:Key="LayerCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="#F4FAFF"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Padding"     Value="6,0,0,0"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Layer list row container ─────────────────────── -->
        <Style x:Key="LayerRowStyle" TargetType="ListBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Padding"     Value="8,5"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder"
                                        Property="Background" Value="#313D4D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder"
                                        Property="Background" Value="#1A3D28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ListBox (layer list) ──────────────────────────── -->
        <Style x:Key="LayerListStyle" TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ── Alert popup Border ────────────────────────────── -->
        <Style x:Key="PopupCardStyle" TargetType="Border">
            <Setter Property="Background"       Value="#F4FAFF"/>
            <Setter Property="BorderBrush"      Value="#208A3C"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="6"/>
            <Setter Property="Padding"          Value="24"/>
            <Setter Property="Effect"           Value="{StaticResource PopupShadow}"/>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════
         ROOT GRID
    ═══════════════════════════════════════════════════════════ -->
    <Grid>

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border Height="70"
                VerticalAlignment="Top"
                Background="#232933"
                CornerRadius="0,0,12,12"
                Effect="{StaticResource HeaderShadow}"
                Panel.ZIndex="10">
            <Grid Margin="24,0,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Wordmark -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="32" FontWeight="Bold"
                               Foreground="#208A3C" Text="py"/>
                    <TextBlock FontSize="32" FontWeight="SemiBold"
                               Foreground="#F4FAFF" Text="Layer Manager"/>
                </StackPanel>

                <!-- Header close button -->
                <Button x:Name="header_close_btn"
                        Grid.Column="1"
                        Style="{StaticResource CloseButtonStyle}"
                        Content="&#x2716;"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Main scroll content ───────────────────────────── -->
        <ScrollViewer Margin="24,90,24,24"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- CAD file info card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabelStyle}"
                                   Text="CAD File"/>
                        <TextBlock x:Name="cad_name_lbl"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="No file selected"
                                   FontSize="12"
                                   Opacity="0.75"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- Search + bulk actions card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabelStyle}"
                                   Text="Layers"/>

                        <!-- Search row -->
                        <DockPanel Margin="0,0,0,10">
                            <TextBox x:Name="search_tb"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     DockPanel.Dock="Left"
                                     Width="Auto"/>
                        </DockPanel>

                        <!-- Placeholder text on top of search box -->
                        <Grid Margin="0,-38,0,10">
                            <TextBlock x:Name="search_placeholder_lbl"
                                       Text="Search layers…"
                                       Foreground="#2B3340"
                                       FontSize="12"
                                       Opacity="0.45"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>

                        <!-- Show all / Hide all -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <Button x:Name="show_all_btn"
                                    Content="Show All"
                                    Style="{StaticResource SmallButtonStyle}"
                                    Width="80"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="hide_all_btn"
                                    Content="Hide All"
                                    Style="{StaticResource SmallButtonStyle}"
                                    Background="#C53030"
                                    Width="80"/>
                        </StackPanel>

                        <!-- Layer count summary -->
                        <TextBlock x:Name="layer_count_lbl"
                                   Foreground="#F4FAFF"
                                   FontSize="11"
                                   Opacity="0.6"
                                   Margin="0,0,0,8"
                                   Text="0 layers"/>

                        <!-- Layer list -->
                        <Border Background="#232933"
                                CornerRadius="6"
                                Padding="4"
                                MaxHeight="320">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ListBox x:Name="layer_list"
                                         Style="{StaticResource LayerListStyle}"
                                         ItemContainerStyle="{StaticResource LayerRowStyle}">
                                    <!-- Items added in Python -->
                                    <!-- Each item is a CheckBox with LayerCheckBoxStyle -->
                                </ListBox>
                            </ScrollViewer>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Apply / Cancel buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,0">
                    <Button x:Name="cancel_btn"
                            Content="Cancel"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="100"
                            Margin="0,0,10,0"/>
                    <Button x:Name="apply_btn"
                            Content="Apply Changes"
                            Style="{StaticResource SmallButtonStyle}"
                            Height="Auto"
                            Padding="16,8"
                            FontSize="12"
                            Width="130"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════════════════
             OVERLAY  (modal backdrop — Visibility toggled in Python)
        ═══════════════════════════════════════════════════════ -->
        <Border x:Name="modal_overlay"
                Background="#000000"
                Opacity="0.6"
                Visibility="Collapsed"
                Panel.ZIndex="999"/>

        <!-- ══════════════════════════════════════════════════════
             ALERT POPUP  (replaces forms.alert — driven from Python)
        ═══════════════════════════════════════════════════════ -->
        <Border x:Name="alert_popup"
                Style="{StaticResource PopupCardStyle}"
                Width="360"
                MaxHeight="250"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed"
                Panel.ZIndex="1000">
            <StackPanel>
                <!-- Title -->
                <TextBlock x:Name="alert_title_lbl"
                           Text="Alert"
                           Foreground="#208A3C"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <!-- Message -->
                <TextBlock x:Name="alert_msg_lbl"
                           Text=""
                           Foreground="#2B3340"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>
                <!-- OK button -->
                <Button x:Name="alert_ok_btn"
                        Content="OK"
                        Style="{StaticResource SmallButtonStyle}"
                        HorizontalAlignment="Right"
                        Width="80"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             CONFIRM POPUP  (Cancel → revert confirmation)
        ═══════════════════════════════════════════════════════ -->
        <Border x:Name="confirm_popup"
                Style="{StaticResource PopupCardStyle}"
                Width="360"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed"
                Panel.ZIndex="1000">
            <StackPanel>
                <TextBlock Text="Revert Changes?"
                           Foreground="#208A3C"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <TextBlock Text="All layer visibility changes will be undone and restored to how they were when you opened this window."
                           Foreground="#2B3340"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="confirm_no_btn"
                            Content="Keep Changes"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,4"
                            Height="24"
                            FontSize="11"
                            Margin="0,0,8,0"/>
                    <Button x:Name="confirm_yes_btn"
                            Content="Yes, Revert"
                            Style="{StaticResource SmallButtonStyle}"
                            Background="#C53030"
                            Width="90"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
