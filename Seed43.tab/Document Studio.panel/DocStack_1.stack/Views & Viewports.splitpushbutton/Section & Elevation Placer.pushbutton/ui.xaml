<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select View Template"
        Height="550"
        Width="450"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="CardBackground" Color="#2B3340"/>
        <SolidColorBrush x:Key="AccentColor" Color="#208A3C"/>
        <SolidColorBrush x:Key="LightText" Color="#F4FAFF"/>
        <SolidColorBrush x:Key="DarkText" Color="#2B3340"/>
        
        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#208A3C"/>
            <Setter Property="Foreground" Value="#F4FAFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#2B933F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#1A6B2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Close Button Style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F4FAFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#FF5555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#CC4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Section Label Style -->
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4FAFF"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,12,0,8"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        
        <!-- Title Style -->
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#208A3C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>
    
    <!-- Main Dialog Card -->
    <Border Background="{StaticResource CardBackground}"
            CornerRadius="8"
            Padding="16">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.2" ShadowDepth="2" BlurRadius="4"/>
        </Border.Effect>
        
        <Grid>
            <!-- Close Button -->
            <Button x:Name="close_btn" 
                    Content="✖" 
                    Style="{StaticResource CloseButtonStyle}" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Margin="0,8,8,0"/>
            
            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,40,0,0">
                <StackPanel Margin="0,0,0,16">
                    <!-- Title -->
                    <TextBlock Text="Select View Template" 
                               Style="{StaticResource TitleStyle}"/>
                    
                    <!-- Last Template Section (if applicable) -->
                    <TextBlock Text="Use Last Template?" 
                               Style="{StaticResource SectionLabelStyle}"/>
                    <Button Content="Standard Template" 
                            Style="{StaticResource ModernButtonStyle}"
                            Width="350"/>
                    
                    <!-- Other Templates Section -->
                    <TextBlock Text="Or Select a Different Template:" 
                               Style="{StaticResource SectionLabelStyle}"/>
                    
                    <!-- Template List -->
                    <Button Content="&lt;None - No Template&gt;" 
                            Style="{StaticResource ModernButtonStyle}"
                            Width="350"/>
                    <Button Content="Architectural Plan" 
                            Style="{StaticResource ModernButtonStyle}"
                            Width="350"/>
                    <Button Content="Construction Detail" 
                            Style="{StaticResource ModernButtonStyle}"
                            Width="350"/>
                    <Button Content="Structural Plan" 
                            Style="{StaticResource ModernButtonStyle}"
                            Width="350"/>
                    <Button Content="MEP Plan" 
                            Style="{StaticResource ModernButtonStyle}"
                            Width="350"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>