            </Border>

        </Grid>


        <!-- ══════════════════════════════════════════════════════════
             OPTIONS PANEL
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="OptionsPanel"
              Background="#3B4553"
              Margin="0,0,0,0"
              Visibility="Collapsed"
              Panel.ZIndex="51"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Import card -->
            <StackPanel Grid.Row="0" Margin="24,12,24,0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Import from CSV / Excel"
                                   Style="{StaticResource SectionLabelStyle}"/>
                        <TextBlock Text="File Path" Style="{StaticResource FieldLabelStyle}"/>
                        <DockPanel Margin="0,0,0,8">
                            <Button x:Name="opt_browse_file_btn"
                                    Content="Browse"
                                    Style="{StaticResource SmallButtonStyle}"
                                    DockPanel.Dock="Right"
                                    Margin="8,0,0,0"
                                    Width="80"/>
                            <TextBox x:Name="opt_file_path_tb"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     IsReadOnly="True"/>
                        </DockPanel>
                        <Button x:Name="opt_import_btn"
                                Content="Import"
                                Style="{StaticResource SmallButtonStyle}"
                                Width="80" HorizontalAlignment="Right" IsEnabled="False"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Tab buttons -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="24,0,24,0">
                <UniformGrid Rows="1">
                    <Button x:Name="opt_reason_tab_btn"
                            Content="Reason"
                            Style="{StaticResource SmallButtonStyle}"
                            Margin="0,0,6,0"/>
                    <Button x:Name="opt_method_tab_btn"
                            Content="Method"
                            Style="{StaticResource SmallButtonStyle}"
                            Background="#404553"
                            Margin="0,0,6,0"/>
                    <Button x:Name="opt_format_tab_btn"
                            Content="Document"
                            Style="{StaticResource SmallButtonStyle}"
                            Background="#404553"
                            Margin="0,0,6,0"/>
                    <Button x:Name="opt_printsize_tab_btn"
                            Content="Print"
                            Style="{StaticResource SmallButtonStyle}"
                            Background="#404553"/>
                </UniformGrid>
            </Border>

            <!-- Search & Add/Delete -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="24,12,24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Search" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="opt_search_tb"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button x:Name="opt_add_btn"
                                Content="+ Add"
                                Style="{StaticResource SmallButtonStyle}"
                                Width="80" Margin="0,0,8,0"/>
                        <Button x:Name="opt_delete_btn"
                                Content="Delete"
                                Style="{StaticResource SmallButtonStyle}"
                                Background="#C53030"
                                Width="80"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DataGrids (one per tab) -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="24,12,24,24" Padding="0" MaxHeight="320">
                <Grid>
                    <DataGrid x:Name="opt_reason_grid" Visibility="Visible"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource MacScrollBar}"/>
                                </DataGrid.Resources>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridColumnHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}"/>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}"/>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="opt_reason_ctx_select_all"  Header="Select All"/>
                                <MenuItem x:Name="opt_reason_ctx_select_none" Header="Select None" Visibility="Collapsed"/>
                                <Separator/>
                                <MenuItem x:Name="opt_reason_ctx_duplicate" Header="Duplicate Row"/>
                                <Separator/>
                                <MenuItem x:Name="opt_reason_ctx_delete"    Header="Delete"/>
                                <Separator/>
                                <MenuItem x:Name="opt_reason_ctx_copy"      Header="Copy to Clipboard"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code"             Binding="{Binding Code}"        Width="80"/>
                            <DataGridTextColumn Header="Separator"        Binding="{Binding Separator}"   Width="80"/>
                            <DataGridTextColumn Header="Reason for Issue" Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid x:Name="opt_method_grid" Visibility="Collapsed"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource MacScrollBar}"/>
                                </DataGrid.Resources>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridColumnHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}"/>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}"/>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="opt_method_ctx_select_all"  Header="Select All"/>
                                <MenuItem x:Name="opt_method_ctx_select_none" Header="Select None" Visibility="Collapsed"/>
                                <Separator/>
                                <MenuItem x:Name="opt_method_ctx_duplicate" Header="Duplicate Row"/>
                                <Separator/>
                                <MenuItem x:Name="opt_method_ctx_delete"    Header="Delete"/>
                                <Separator/>
                                <MenuItem x:Name="opt_method_ctx_copy"      Header="Copy to Clipboard"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code"            Binding="{Binding Code}"        Width="80"/>
                            <DataGridTextColumn Header="Separator"       Binding="{Binding Separator}"   Width="80"/>
                            <DataGridTextColumn Header="Method of Issue" Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid x:Name="opt_format_grid" Visibility="Collapsed"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource MacScrollBar}"/>
                                </DataGrid.Resources>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridColumnHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}"/>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}"/>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="opt_format_ctx_select_all"  Header="Select All"/>
                                <MenuItem x:Name="opt_format_ctx_select_none" Header="Select None" Visibility="Collapsed"/>
                                <Separator/>
                                <MenuItem x:Name="opt_format_ctx_duplicate" Header="Duplicate Row"/>
                                <Separator/>
                                <MenuItem x:Name="opt_format_ctx_delete"    Header="Delete"/>
                                <Separator/>
                                <MenuItem x:Name="opt_format_ctx_copy"      Header="Copy to Clipboard"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Document Format" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid x:Name="opt_printsize_grid" Visibility="Collapsed"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource MacScrollBar}"/>
                                </DataGrid.Resources>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridColumnHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}"/>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}"/>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="opt_printsize_ctx_select_all"  Header="Select All"/>
                                <MenuItem x:Name="opt_printsize_ctx_select_none" Header="Select None" Visibility="Collapsed"/>
                                <Separator/>
                                <MenuItem x:Name="opt_printsize_ctx_duplicate" Header="Duplicate Row"/>
                                <Separator/>
                                <MenuItem x:Name="opt_printsize_ctx_delete"    Header="Delete"/>
                                <Separator/>
                                <MenuItem x:Name="opt_printsize_ctx_copy"      Header="Copy to Clipboard"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Print Size" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>


        <!-- ══════════════════════════════════════════════════════════
             EXPORT SETTINGS PANEL
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="ExportSettingsPanel"
              Background="#3B4553"
              Margin="0,0,0,0"
              Visibility="Collapsed"
              Panel.ZIndex="52"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch">
            <ScrollViewer Style="{StaticResource MacScrollViewer}" HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                <StackPanel Margin="24,12,24,24" HorizontalAlignment="Stretch">

                    <!-- Info card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Export Settings"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <TextBlock Text="Note: settings will be exported into a folder named  pyTransmit Settings  at the chosen location."
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.7"
                                       TextWrapping="Wrap" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Auto-update + file path card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <CheckBox x:Name="export_auto_update_cb"
                                      Content="Auto update changes"
                                      Foreground="#F4FAFF" FontSize="12"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="When enabled, every Save will automatically copy updated files to the export folder, to update other user settings."
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.6"
                                       TextWrapping="Wrap" Margin="20,0,0,16"/>

                            <TextBlock Text="Export Folder" Style="{StaticResource FieldLabelStyle}"/>
                            <DockPanel Margin="0,0,0,0">
                                <Button x:Name="export_browse_btn"
                                        Content="Browse"
                                        Style="{StaticResource SmallButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Width="80" Margin="8,0,0,0"
                                        Click="export_browse_click"/>
                                <TextBox x:Name="export_path_tb"
                                         Style="{StaticResource ModernTextBoxStyle}"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- What to export card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Select items to export"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <CheckBox x:Name="export_recipients_cb"
                                      Content="Recipients"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="export_reason_cb"
                                      Content="Reason for Issue"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="export_method_cb"
                                      Content="Method of Issue"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="export_format_cb"
                                      Content="Document Type"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="export_printsize_cb"
                                      Content="Print Size"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="export_layouts_cb"
                                      Content="Document Layout Templates"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E2730" CornerRadius="6" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#208A3C" CornerRadius="3,0,0,3"/>
                            <TextBlock Grid.Column="1" Text="&#x2139;" Foreground="#208A3C" FontSize="13" Margin="10,8,8,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Settings are saved automatically when you close this panel."
                                       Foreground="#7EC8A0" FontSize="10" Opacity="0.9"
                                       TextWrapping="Wrap" Margin="0,8,8,8" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             IMPORT SETTINGS PANEL
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="ImportSettingsPanel"
              Background="#3B4553"
              Margin="0,0,0,0"
              Visibility="Collapsed"
              Panel.ZIndex="52"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch">
            <ScrollViewer Style="{StaticResource MacScrollViewer}" HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                <StackPanel Margin="24,12,24,24" HorizontalAlignment="Stretch">

                    <!-- Info card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Import Settings"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <TextBlock Text="Browse to a  pyTransmit Settings  folder to import settings from."
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.7"
                                       TextWrapping="Wrap" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Auto-update + file path card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <CheckBox x:Name="import_auto_update_cb"
                                      Content="Auto update on startup"
                                      Foreground="#F4FAFF" FontSize="12"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="When enabled, the selected files are automatically imported from this folder each time pyTransmit opens."
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.6"
                                       TextWrapping="Wrap" Margin="20,0,0,16"/>

                            <TextBlock Text="Import Folder (pyTransmit Settings)" Style="{StaticResource FieldLabelStyle}"/>
                            <DockPanel Margin="0,0,0,0">
                                <Button x:Name="import_browse_btn"
                                        Content="Browse"
                                        Style="{StaticResource SmallButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Width="80" Margin="8,0,0,0"
                                        Click="import_browse_click"/>
                                <TextBox x:Name="import_path_tb"
                                         Style="{StaticResource ModernTextBoxStyle}"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- What to import card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Select items to import"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <CheckBox x:Name="import_recipients_cb"
                                      Content="Recipients"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="import_reason_cb"
                                      Content="Reason for Issue"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="import_method_cb"
                                      Content="Method of Issue"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="import_format_cb"
                                      Content="Document Type"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="import_printsize_cb"
                                      Content="Print Size"
                                      Foreground="#F4FAFF" FontSize="12" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E2730" CornerRadius="6" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#208A3C" CornerRadius="3,0,0,3"/>
                            <TextBlock Grid.Column="1" Text="&#x2139;" Foreground="#208A3C" FontSize="13" Margin="10,8,8,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Settings are saved automatically when you close this panel."
                                       Foreground="#7EC8A0" FontSize="10" Opacity="0.9"
                                       TextWrapping="Wrap" Margin="0,8,8,8" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
        <!-- ══════════════════════════════════════════════════════════
             FILE NAMING PANEL
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="FileNamingPanel"
              Background="#3B4553"
              Margin="0,0,0,0"
              Visibility="Collapsed"
              Panel.ZIndex="52"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch">
            <ScrollViewer Style="{StaticResource MacScrollViewer}" HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                <StackPanel Margin="24,12,24,24">

                    <!-- ── NAMING TEMPLATE ────────────────────────────── -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Transmittal Naming Template"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.7"
                                       Margin="0,0,0,8">
                                Build your file name using the tokens below. Drag a token into the template field to insert. The extension is added automatically.
                            </TextBlock>

                            <!-- Template input -->
                            <TextBox x:Name="filenaming_template_tb"
                                     Height="32" Padding="8,4"
                                     Background="#F4FAFF" Foreground="#2B3340"
                                     BorderBrush="#208A3C" BorderThickness="1"
                                     FontFamily="Consolas" FontSize="12"
                                     VerticalContentAlignment="Center"
                                     AllowDrop="True"
                                     PreviewDrop="filenaming_stop_drag"
                                     PreviewDragOver="filenaming_preview_drag"
                                     ToolTip="Type or drag tokens to build the naming template"/>

                            <!-- Preview -->
                            <TextBlock Text="Preview"
                                       Foreground="#F4FAFF" FontSize="10"
                                       Opacity="0.55" Margin="0,8,0,2"/>
                            <TextBox x:Name="filenaming_preview_tb"
                                     Height="28" Padding="8,4"
                                     Background="#232933" Foreground="#7EC8A0"
                                     BorderBrush="#404553" BorderThickness="1"
                                     FontFamily="Consolas" FontSize="11"
                                     VerticalContentAlignment="Center"
                                     IsReadOnly="True"/>

                            <!-- Token chips — populated entirely in code (IronPython 2 safe) -->
                            <TextBlock Text="Available tokens — drag into the template field above"
                                       Foreground="#F4FAFF" FontSize="10" Opacity="0.55"
                                       Margin="0,12,0,4"/>
                            <WrapPanel x:Name="filenaming_formatters_wp"
                                       Margin="0,0,0,0"
                                       PreviewMouseLeftButtonDown="filenaming_start_drag"/>

                        </StackPanel>
                    </Border>

                    <!-- ── PROJECT FOLDER LOCATIONS ───────────────────── -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Project Folder Locations"
                                       Style="{StaticResource SectionLabelStyle}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.7"
                                       Margin="0,0,0,12">
                                Set the root folder(s) where project folders are stored. Leave Older Jobs blank if not applicable.
                            </TextBlock>

                            <!-- Main root -->
                            <TextBlock Text="Projects Root"
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.85"
                                       Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="filenaming_projects_root_tb"
                                         Grid.Column="0"
                                         Height="28" Padding="6,4" Margin="0,0,6,0"
                                         Background="#2B3342" Foreground="#F4FAFF"
                                         BorderBrush="#5B6A82" BorderThickness="1"
                                         FontSize="11"
                                         ToolTip="Root folder containing range-bucket subfolders e.g. N:\#JOB\"/>
                                <Button x:Name="filenaming_projects_root_browse_btn"
                                        Grid.Column="1"
                                        Content="Browse..."
                                        Style="{StaticResource SmallButtonStyle}"
                                        Width="72" Height="28"/>
                            </Grid>

                            <!-- Older jobs root -->
                            <TextBlock Text="Older Jobs Root (optional)"
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.85"
                                       Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="filenaming_older_root_tb"
                                         Grid.Column="0"
                                         Height="28" Padding="6,4" Margin="0,0,6,0"
                                         Background="#2B3342" Foreground="#F4FAFF"
                                         BorderBrush="#5B6A82" BorderThickness="1"
                                         FontSize="11"
                                         ToolTip="Secondary root for archived/older jobs e.g. N:\#JOB\Older Jobs\"/>
                                <Button x:Name="filenaming_older_root_browse_btn"
                                        Grid.Column="1"
                                        Content="Browse..."
                                        Style="{StaticResource SmallButtonStyle}"
                                        Width="72" Height="28"/>
                            </Grid>

                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#7EC8A0" FontSize="10" Opacity="0.85"
                                       Margin="0,6,0,0">
                                Any folder structure is supported as long as range buckets
                                are named with a -{start}-{end} suffix (e.g. #JOB-2500-2550).
                                Project subfolders must start with the job number.
                            </TextBlock>

                            <!-- Path template -->
                            <TextBlock Text="Output Path Template"
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.85"
                                       Margin="0,12,0,4"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#F4FAFF" FontSize="11" Opacity="0.7"
                                       Margin="0,0,0,8">
                                Build the full output folder path using tokens. Drag tokens into the template field to insert.
                            </TextBlock>
                            <TextBox x:Name="filenaming_path_template_tb"
                                     Height="32" Padding="8,4"
                                     Background="#F4FAFF" Foreground="#2B3340"
                                     BorderBrush="#208A3C" BorderThickness="1"
                                     FontFamily="Consolas" FontSize="11"
                                     VerticalContentAlignment="Center"
                                     AllowDrop="True"
                                     PreviewDrop="filenaming_path_stop_drag"
                                     PreviewDragOver="filenaming_path_preview_drag"
                                     ToolTip="e.g. {projects_root}\{bucket}\{job_number} - {client}\Transmittals"/>

                            <!-- Path preview -->
                            <TextBlock Text="Preview"
                                       Foreground="#F4FAFF" FontSize="10"
                                       Opacity="0.55" Margin="0,8,0,2"/>
                            <TextBox x:Name="filenaming_path_preview_tb"
                                     Height="28" Padding="8,4"
                                     Background="#232933" Foreground="#7EC8A0"
                                     BorderBrush="#404553" BorderThickness="1"
                                     FontFamily="Consolas" FontSize="11"
                                     VerticalContentAlignment="Center"
                                     IsReadOnly="True"/>

                            <!-- Path token chips — populated in code -->
                            <TextBlock Text="Available tokens — drag into the path field above"
                                       Foreground="#F4FAFF" FontSize="10" Opacity="0.55"
                                       Margin="0,12,0,4"/>
                            <WrapPanel x:Name="filenaming_path_formatters_wp"
                                       Margin="0,0,0,0"
                                       PreviewMouseLeftButtonDown="filenaming_path_start_drag"/>

                        </StackPanel>
                    </Border>

                    <Border Background="#1E2730" CornerRadius="6" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#208A3C" CornerRadius="3,0,0,3"/>
                            <TextBlock Grid.Column="1" Text="&#x2139;" Foreground="#208A3C" FontSize="13" Margin="10,8,8,8" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Settings are saved automatically when you close this panel."
                                       Foreground="#7EC8A0" FontSize="10" Opacity="0.9"
                                       TextWrapping="Wrap" Margin="0,8,8,8" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- AboutModal shell kept for legacy close_about_click handler — content served via browser -->
        <Border x:Name="AboutModal"
                Visibility="Collapsed"
                Panel.ZIndex="1000">
            <Button x:Name="close_about_btn"
                    Visibility="Collapsed"
                    Click="close_about_click"/>
        </Border>
    </DockPanel>
</Window>