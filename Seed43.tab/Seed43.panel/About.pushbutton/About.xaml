<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Seed43"
    Width="500"
    SizeToContent="Height"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    TextElement.FontFamily="Segoe UI"
    Background="#3B4553">
<Window.Resources>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"      Value="#2B3340"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="BorderBrush"     Value="#208A3C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin"          Value="0,0,0,12"/>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#208A3C"/>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="Foreground"   Value="#F4FAFF"/>
        <Setter Property="Opacity"      Value="0.9"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="DimLabel" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="Foreground"   Value="#A0AABB"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Tool manager styles -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"      Value="#2B3340"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="BorderBrush"     Value="#208A3C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin"          Value="0,0,0,8"/>
        <Setter Property="Padding"         Value="4"/>
    </Style>

    <Style x:Key="Title" TargetType="TextBlock">
        <Setter Property="Foreground"        Value="#208A3C"/>
        <Setter Property="FontSize"          Value="13"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ToolText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#F4FAFF"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Opacity"    Value="0.9"/>
    </Style>

    <Style x:Key="PulldownHeader" TargetType="TextBlock">
        <Setter Property="Foreground"        Value="#208A3C"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PulldownCard" TargetType="Border">
        <Setter Property="Background"      Value="#232933"/>
        <Setter Property="BorderBrush"     Value="#208A3C"/>
        <Setter Property="BorderThickness" Value="2,0,0,0"/>
        <Setter Property="CornerRadius"    Value="0,4,4,0"/>
        <Setter Property="Margin"          Value="12,3,4,3"/>
    </Style>

    <Style x:Key="StandaloneCard" TargetType="Border">
        <Setter Property="Background"      Value="#232933"/>
        <Setter Property="BorderBrush"     Value="#4A5568"/>
        <Setter Property="BorderThickness" Value="2,0,0,0"/>
        <Setter Property="CornerRadius"    Value="0,4,4,0"/>
        <Setter Property="Margin"          Value="12,3,4,3"/>
    </Style>

    <Style x:Key="SecondaryBtn" TargetType="Button">
        <Setter Property="Background"      Value="#404553"/>
        <Setter Property="Foreground"      Value="#F4FAFF"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Padding"         Value="16,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4E5566"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#333B48"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</Window.Resources>
<StackPanel>

    <!-- Header -->
    <Border Background="#232933" Height="64">
        <DockPanel Margin="20,0">
            <Button x:Name="footer_reload" Content="Reload PyRevit"
                    Style="{StaticResource SecondaryBtn}"
                    HorizontalAlignment="Right" DockPanel.Dock="Right"
                    VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image x:Name="header_icon"
                       Width="28" Height="28"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
                <TextBlock Text="Seed" FontSize="24" FontWeight="Bold" Foreground="#208A3C"/>
                <TextBlock Text="43"   FontSize="24" Foreground="#F4FAFF"/>
                <TextBlock Text="  |  Tools" FontSize="14" Foreground="#F4FAFF"
                           VerticalAlignment="Bottom" Margin="0,0,0,2" Opacity="0.85"/>
            </StackPanel>
        </DockPanel>
    </Border>

    <!-- Update ribbon (hidden until update detected) -->
    <Border x:Name="update_ribbon" Visibility="Collapsed"
            Background="#D4720A" Cursor="Hand" Padding="20,8">
        <DockPanel>
            <TextBlock Text="&#x25B2;  Update Available — click to update"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="#F4FAFF" VerticalAlignment="Center"/>
            <TextBlock x:Name="update_ribbon_version"
                       Text="" FontSize="11"
                       Foreground="#F4FAFF" Opacity="0.85"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </DockPanel>
    </Border>

    <!-- Body -->
    <StackPanel Margin="20,16,20,20">

        <!-- Seed43 version card -->
        <Border Style="{StaticResource CardStyle}" Padding="16">
            <StackPanel>
                <TextBlock x:Name="s43_title" Text="Checking..."
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#208A3C" Margin="0,0,0,6"/>
                <TextBlock x:Name="s43_changelog" Text=""
                           FontSize="12" Foreground="#F4FAFF"
                           Opacity="0.9" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Tools divider -->
        <TextBlock Text="TOOLS" FontSize="11" FontWeight="SemiBold"
                   Foreground="#A0AABB" Margin="0,0,0,8"/>

        <!-- Dynamic tool list populated by script -->
        <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
            <StackPanel x:Name="tools_container"/>
        </ScrollViewer>

        <!-- Apply order footer -->
        <DockPanel Margin="0,10,0,0">
            <Button x:Name="apply_order_btn" Content="Apply Order"
                    Style="{StaticResource SecondaryBtn}"
                    HorizontalAlignment="Right"/>
        </DockPanel>

    </StackPanel>
</StackPanel>
</Window>
